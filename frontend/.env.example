# -------------------------------------------------------------------
# Vercel Environment Variable Setup
# -------------------------------------------------------------------
# Copy these into: Vercel Dashboard → Your Project → Settings → Environment Variables
# Then redeploy the frontend for changes to take effect.
# -------------------------------------------------------------------

# Required: URL of your deployed Render backend
# Example: https://synapselink-backend.onrender.com
VITE_API_URL=https://YOUR_RENDER_BACKEND_URL.onrender.com
